DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_API_URL=https://api.deepseek.com/v1/chat/completions

# Firebase — download service account JSON from:
# Firebase Console > Project Settings > Service accounts > Generate new private key
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json
FIREBASE_CREDENTIALS_JSON=   # alternative: paste base64 JSON here (for fly.io)
FIREBASE_STORAGE_BUCKET=jobs-e038b.firebasestorage.app

# Email sender (Gmail)
# Use a Gmail App Password: Google Account > Security > 2-Step Verification > App passwords
SENDER_EMAIL=you@gmail.com
SENDER_PASSWORD=your-app-password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
